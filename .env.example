# Bridge LLM Bench - API Keys
# Copy this file to .env and add your API keys

# OpenAI (GPT-5.2, GPT-5.1, GPT-4.1, o3)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude Opus 4.6, Sonnet 4.6)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google (Gemini 3.1 Pro, Gemini 3 Flash, Flash Lite)
GOOGLE_API_KEY=your-google-api-key-here

# DeepSeek (DeepSeek-V3, DeepSeek-R1)
DEEPSEEK_API_KEY=your-deepseek-key-here

# Qwen / Alibaba (Qwen 3.5)
QWEN_API_KEY=your-qwen-key-here

# xAI (Grok 4)
XAI_API_KEY=your-xai-key-here

# Zhipu AI (GLM-5)
ZHIPU_API_KEY=your-zhipu-key-here

# Baidu (ERNIE 5.0)
QIANFAN_API_KEY=your-qianfan-key-here

# Moonshot (Kimi K2.5)
MOONSHOT_API_KEY=your-moonshot-key-here

# Bytedance (Dola Seed 2.0)
DOLA_API_KEY=your-dola-key-here
